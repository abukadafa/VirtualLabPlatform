# Environment Variables

# Server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/virtual-lab

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Docker Resource Limits
MAX_CONCURRENT_CONTAINERS=30
MAX_PER_LAB_TYPE=10
CONTAINER_CPU_LIMIT=2
CONTAINER_MEM_LIMIT=4G
CONTAINER_DISK_LIMIT=20G

# Session Timeouts (minutes)
SESSION_IDLE_WARNING=15
SESSION_IDLE_PAUSE=30
SESSION_IDLE_STOP=120
SESSION_CLEANUP_DAYS=1

# Guacamole
GUAC_REST_API_URL=http://localhost:8080/guacamole/api
GUACAMOLE_ADMIN_PASSWORD=guacadmin
GUACAMOLE_BASE_URL=http://localhost:8080

# Guacamole Database (for docker-compose)
GUAC_DB_NAME=guacamole_db
GUAC_DB_USER=guacamole_user
GUAC_DB_PASSWORD=guacamole_password

# Network Configuration (per-lab internet access)
AI_LAB_INTERNET=true
CYBER_LAB_INTERNET=true
MIS_LAB_INTERNET=false

# Redis (for BullMQ queue management)
REDIS_HOST=localhost
REDIS_PORT=6379

# Monitoring
# (set `PROXMOX_ALLOW_INSECURE_TLS=true` when using a self-signed Proxmox cert)
ENABLE_METRICS=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Proxmox TLS
PROXMOX_ALLOW_INSECURE_TLS=false
# Proxmox API timeout in milliseconds (increase if template fetches are slow)
PROXMOX_API_TIMEOUT_MS=45000
