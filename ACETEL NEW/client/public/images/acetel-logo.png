<svg width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Circular Background -->
  <circle cx="100" cy="100" r="90" fill="black" />
  
  <!-- Stylized Globe -->
  <circle cx="100" cy="100" r="60" fill="url(#globeGradient)" />
  
  <!-- Outer Swooshes/Arrows -->
  <path d="M40 100C40 60 70 30 110 30C150 30 180 60 180 100" stroke="#4ADE80" stroke-width="8" stroke-linecap="round" />
  <path d="M160 100C160 140 130 170 90 170C50 170 20 140 20 100" stroke="#F97316" stroke-width="8" stroke-linecap="round" />
  
  <!-- ACETEL Text -->
  <text x="100" y="115" font-family="Arial, sans-serif" font-weight="bold" font-size="28" fill="#EF4444" text-anchor="middle">ACETEL</text>
  
  <defs>
    <radialGradient id="globeGradient" cx="0" cy="0" r="1" gradientUnits="userSpaceOnUse" gradientTransform="translate(100 100) rotate(90) scale(60)">
      <stop offset="0" stop-color="#3B82F6" />
      <stop offset="1" stop-color="#22C55E" />
    </radialGradient>
  </defs>
</svg>
