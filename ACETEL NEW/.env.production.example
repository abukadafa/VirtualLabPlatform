# --- SERVER CONFIG ---
PORT=5000
NODE_ENV=production
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE
CORS_ORIGIN=https://your-frontend-domain.com
ALLOW_PROD_SEED=false

# --- DATABASE CONFIG ---
MONGODB_URI=mongodb://mongodb:27017/virtuallab
REDIS_HOST=redis
GUAC_DB_PASSWORD=YOUR_SECURE_DB_PASSWORD_HERE

# --- LAB CONFIG ---
MAX_CONCURRENT_CONTAINERS=100
MAX_PER_LAB_TYPE=40

# Note: VITE_API_URL is set as a build argument in the Dockerfile.
# To build for production, use: 
# docker build --build-arg VITE_API_URL=https://api.domain.com -t your-image-name .
VITE_API_URL=https://your-domain.com/api
