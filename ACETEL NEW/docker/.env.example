# ===========================================
# Virtual Lab Platform - Environment Configuration
# ===========================================

# Resource Limits
MAX_CONCURRENT_CONTAINERS=30
MAX_PER_LAB_TYPE=10
CONTAINER_CPU_LIMIT=2
CONTAINER_MEM_LIMIT=4G
CONTAINER_DISK_LIMIT=20G

# Session Timeouts (minutes)
SESSION_IDLE_WARNING=15
SESSION_IDLE_PAUSE=30
SESSION_IDLE_STOP=120
SESSION_CLEANUP_DAYS=1

# Backup Strategy
BACKUP_REAL_TIME=true           # Continuous volume snapshots
BACKUP_HOURLY_METADATA=true    # Session state & audit logs
BACKUP_DAILY_FULL=true          # Full volume backups
BACKUP_WEEKLY_ARCHIVE=true      # Long-term archive
BACKUP_RETENTION_DAYS=30

# Guacamole Configuration
GUAC_AMOLE_ADMIN_PASSWORD=change_me_in_production
GUACAMOLE_DB_PASSWORD=change_me_in_production
GUAC_REST_API_URL=http://guacamole:8080/guacamole/api

# Network Configuration (per-lab configurable)
AI_LAB_INTERNET=true        # Need pip install, dataset downloads
CYBER_LAB_INTERNET=true     # Real-world testing scenarios
MIS_LAB_INTERNET=false      # Mostly database work
LAB_NETWORK_SUBNET=172.20.0.0/16

# Egress Filtering (whitelist approach when internet enabled)
ALLOWED_DOMAINS=pypi.org,pytorch.org,tensorflow.org,github.com,huggingface.co,anaconda.org,conda.io

# Monitoring
ENABLE_METRICS=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=change_me_in_production

# Database (MongoDB for backend)
MONGODB_URI=mongodb://mongo:27017/virtuallab
MONGODB_USER=admin
MONGODB_PASSWORD=change_me_in_production

# Backend API
API_PORT=3000
JWT_SECRET=change_me_in_production_use_long_random_string

# Queue Configuration (BullMQ)
REDIS_HOST=redis
REDIS_PORT=6379
MAX_QUEUED_PER_USER=1
MAX_QUEUE_REJOIN_ATTEMPTS=3
COOLDOWN_AFTER_STOP=60

# Logging
LOG_LEVEL=info
LOG_DRIVER=json-file  # For development, use "fluentd" for production

# Development vs Production
NODE_ENV=development
# NODE_ENV=production

# Cloud Provider (for future deployment)
# CLOUD_PROVIDER=aws|azure|gcp
# AWS_REGION=us-east-1
# AZURE_REGION=eastus
# GCP_PROJECT_ID=your-project-id
